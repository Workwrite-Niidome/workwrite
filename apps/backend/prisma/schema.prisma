generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// Auth & Users
// ============================================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String?
  name          String
  displayName   String?
  avatarUrl     String?
  bio           String?
  role          UserRole  @default(READER)
  isBanned      Boolean   @default(false)
  emailVerified Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  oauthAccounts   OAuthAccount[]
  onboarding      OnboardingResult?
  works           Work[]
  episodes        Episode[]
  readingProgress ReadingProgress[]
  bookshelf       BookshelfEntry[]
  highlights      Highlight[]
  emotionTags     UserEmotionTag[]
  reviews         Review[]
  reviewHelpfuls  ReviewHelpful[]
  stateChanges    StateChange[]
  points          PointAccount?
  pointHistory    PointTransaction[]
  comments        Comment[]
  notifications   Notification[]

  // Following
  following  Follow[] @relation("follower")
  followers  Follow[] @relation("following")

  // SNS
  posts         Post[]         @relation("PostAuthor")
  applause      Applause[]
  postBookmarks PostBookmark[]

  // Letters
  lettersSent     Letter[] @relation("lettersSent")
  lettersReceived Letter[] @relation("lettersReceived")

  // Referral
  referralCode    String?  @unique
  referralCredits Int      @default(0)
  referredBy      String?  // userId of who referred this user
  referralCount   Int      @default(0) // how many users this user has referred

  // Stripe
  stripeCustomerId  String?
  stripeAccountId   String?
  subscription      Subscription?

  // Credits
  creditBalance       CreditBalance?
  creditTransactions  CreditTransaction[]
  creditPurchases     CreditPurchase[]

  // AI Generation History
  aiGenerations AiGenerationHistory[]

  // Editor Mode
  editorModeJobs EditorModeJob[]

  // Episode Reactions
  episodeReactions EpisodeReaction[]

  // Announcements
  announcements Announcement[] @relation("announcementCreator")

  @@index([email])
  @@index([role])
}

enum UserRole {
  READER
  AUTHOR
  EDITOR
  ADMIN
}

model OAuthAccount {
  id         String   @id @default(cuid())
  userId     String
  provider   String   // google, x, apple
  providerId String
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerId])
  @@index([userId])
}

model OnboardingResult {
  id              String   @id @default(cuid())
  userId          String   @unique
  answers         Json     // 5-item diagnosis answers
  emotionVector   Json     // initial emotion vector
  aiProfile       Json?
  completedAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("follower", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

// ============================================================
// Works & Episodes
// ============================================================

model Work {
  id          String     @id @default(cuid())
  authorId    String
  title       String
  synopsis    String?    @db.Text
  prologue    String?    @db.Text
  coverUrl    String?
  status           WorkStatus       @default(DRAFT)
  completionStatus CompletionStatus @default(ONGOING)
  genre            String?
  settingEra       String?          // 時代・世界観設定（例: 中世ヨーロッパ風ファンタジー、現代日本、近未来SF）
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  publishedAt DateTime?

  // Relations
  author         User              @relation(fields: [authorId], references: [id])
  episodes       Episode[]
  tags           WorkTag[]
  emotionTags    UserEmotionTag[]
  qualityScore   QualityScore?
  bookshelfEntries BookshelfEntry[]
  reviews        Review[]
  stateChanges   StateChange[]
  series         SeriesWork[]
  readingProgress ReadingProgress[]
  aiInsights    AiInsight[]
  embedding     WorkEmbedding?

  // AI Creation
  originality     Float?
  creationPlan    WorkCreationPlan?
  aiCreationLogs  AiCreationLog[]

  // Story Structure
  storyCharacters StoryCharacter[]
  storyArc        StoryArc?

  // AI Generation History
  aiGenerations     AiGenerationHistory[]

  // AI Structural Analysis
  episodeAnalyses   EpisodeAnalysis[]
  foreshadowings    Foreshadowing[]
  worldSettings     WorldSetting[]
  dialogueSamples   CharacterDialogueSample[]

  // SNS
  posts Post[]

  // AI-generated content flag
  isAiGenerated       Boolean @default(false)
  enableCharacterTalk Boolean @default(true)

  // Editor Mode
  editorModeJob  EditorModeJob?

  // Episode Reactions
  episodeReactions EpisodeReaction[]

  // Denormalized stats
  totalViews     Int @default(0)
  totalReads     Int @default(0) // completed reads

  @@index([authorId])
  @@index([status])
  @@index([genre])
  @@index([publishedAt])
  @@index([totalViews])
  @@index([status, isAiGenerated])
}

enum WorkStatus {
  DRAFT
  PUBLISHED
  UNPUBLISHED
}

enum CompletionStatus {
  ONGOING    // 連載中
  COMPLETED  // 完結済み
  HIATUS     // 休載中
}

model Episode {
  id          String   @id @default(cuid())
  workId      String
  authorId    String
  title       String
  content     String   @db.Text
  orderIndex  Int
  wordCount   Int      @default(0)
  publishedAt DateTime?
  scheduledAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  work   Work @relation(fields: [workId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id])

  contentVersion      Int      @default(0)
  extractedCharacters Json?    // [{name, role}] — auto-extracted by Haiku on first read

  readingProgress ReadingProgress[]
  highlights      Highlight[]
  comments        Comment[]
  letters         Letter[]
  scenes          StoryScene[]
  aiAnalysis      EpisodeAnalysis?
  posts           Post[]
  reactions       EpisodeReaction[]

  @@unique([workId, orderIndex])
  @@index([workId])
  @@index([authorId])
}

model WorkTag {
  id     String @id @default(cuid())
  workId String
  tag    String
  type   TagType @default(KEYWORD) // genre, keyword, author_emotion

  work Work @relation(fields: [workId], references: [id], onDelete: Cascade)

  @@unique([workId, tag, type])
  @@index([tag])
  @@index([type])
}

enum TagType {
  GENRE
  KEYWORD
  AUTHOR_EMOTION
}

model Series {
  id          String   @id @default(cuid())
  title       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  works SeriesWork[]
}

model SeriesWork {
  id         String @id @default(cuid())
  seriesId   String
  workId     String
  orderIndex Int

  series Series @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  work   Work   @relation(fields: [workId], references: [id], onDelete: Cascade)

  @@unique([seriesId, workId])
  @@unique([seriesId, orderIndex])
}

// ============================================================
// Reading
// ============================================================

model ReadingProgress {
  id         String   @id @default(cuid())
  userId     String
  workId     String
  episodeId  String
  progressPct Float   @default(0) // 0.0 - 1.0
  readTimeMs  Int     @default(0)
  lastPosition Int    @default(0)
  completed   Boolean @default(false)
  updatedAt   DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  work    Work    @relation(fields: [workId], references: [id], onDelete: Cascade)
  episode Episode @relation(fields: [episodeId], references: [id], onDelete: Cascade)

  @@unique([userId, episodeId])
  @@index([userId, workId])
}

model BookshelfEntry {
  id        String         @id @default(cuid())
  userId    String
  workId    String
  status    BookshelfStatus @default(WANT_TO_READ)
  addedAt   DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  work Work @relation(fields: [workId], references: [id], onDelete: Cascade)

  @@unique([userId, workId])
  @@index([userId, status])
}

enum BookshelfStatus {
  WANT_TO_READ
  READING
  COMPLETED
}

model Highlight {
  id        String   @id @default(cuid())
  userId    String
  episodeId String
  startPos  Int
  endPos    Int
  color     String   @default("#FFFF00")
  memo      String?  @db.Text
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  episode Episode @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  posts   Post[]

  @@index([userId, episodeId])
}

model Comment {
  id          String   @id @default(cuid())
  userId      String
  episodeId   String
  paragraphId String?
  parentId    String?
  content     String   @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  episode Episode @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  parent  Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies Comment[] @relation("CommentReplies")

  @@index([episodeId])
  @@index([userId])
  @@index([parentId])
}

// ============================================================
// Letters (有料ファンレター / 投げ銭)
// ============================================================

model Letter {
  id               String       @id @default(cuid())
  senderId         String
  recipientId      String       // 著者のuserId
  episodeId        String
  type             LetterType
  content          String       @db.Text
  amount           Int          // 金額（円）。Free枠使用時は0
  stampId          String?      // スタンプID（STANDARD以上）
  isHighlighted    Boolean      @default(false) // PREMIUM以上: 上部固定表示
  isFreeQuota      Boolean      @default(false) // Free枠使用時 true
  paymentId        String?      // Payment.id
  moderationStatus String       @default("approved") // approved / rejected / pending
  moderationReason String?      // 検閲拒否理由
  createdAt        DateTime     @default(now())

  sender    User    @relation("lettersSent", fields: [senderId], references: [id])
  recipient User    @relation("lettersReceived", fields: [recipientId], references: [id])
  episode   Episode @relation(fields: [episodeId], references: [id], onDelete: Cascade)

  @@index([episodeId])
  @@index([recipientId])
  @@index([senderId])
  @@index([createdAt])
}

enum LetterType {
  SHORT     // ¥120, 140字
  STANDARD  // ¥300, 500字
  PREMIUM   // ¥500, 1000字
  GIFT      // ¥1,000〜, 1000字
}

// ============================================================
// Emotions & Reflection
// ============================================================

model EmotionTagMaster {
  id       String @id @default(cuid())
  name     String @unique
  nameJa   String
  category String
  iconUrl  String?

  userEmotionTags UserEmotionTag[]
}

model UserEmotionTag {
  id        String   @id @default(cuid())
  userId    String
  workId    String
  tagId     String
  intensity Int      @default(3) // 1-5
  createdAt DateTime @default(now())

  user User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  work Work            @relation(fields: [workId], references: [id], onDelete: Cascade)
  tag  EmotionTagMaster @relation(fields: [tagId], references: [id])

  @@unique([userId, workId, tagId])
  @@index([workId])
  @@index([tagId])
}

model StateChange {
  id     String @id @default(cuid())
  userId String
  workId String
  axis   String // e.g., "confidence", "worldview", "empathy"
  before Int    // 1-10
  after  Int    // 1-10
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  work Work @relation(fields: [workId], references: [id], onDelete: Cascade)

  @@unique([userId, workId, axis])
  @@index([userId])
  @@index([workId])
}

model Review {
  id        String   @id @default(cuid())
  userId    String
  workId    String
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  work     Work            @relation(fields: [workId], references: [id], onDelete: Cascade)
  helpfuls ReviewHelpful[]

  @@unique([userId, workId])
  @@index([workId])
}

model ReviewHelpful {
  id        String   @id @default(cuid())
  userId    String
  reviewId  String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@unique([userId, reviewId])
}

// ============================================================
// AI Quality Scoring
// ============================================================

model QualityScore {
  id              String   @id @default(cuid())
  workId          String   @unique
  immersion       Float    // 没入力 0-100
  transformation  Float    // 変容力 0-100
  virality        Float    // 拡散力 0-100
  worldBuilding   Float    // 世界構築力 0-100
  overall         Float    // 統合スコア 0-100
  characterDepth  Float?   // キャラクター深度 0-100
  structuralScore Float?   // 構造スコア 0-100
  analysisJson    Json?    // detailed LLM analysis
  improvementTips Json?    // top 3 improvement suggestions
  scoredAt        DateTime @default(now())
  version         Int      @default(1)

  work Work @relation(fields: [workId], references: [id], onDelete: Cascade)

  @@index([overall])
}

// ============================================================
// Points & Payments
// ============================================================

model PointAccount {
  id      String @id @default(cuid())
  userId  String @unique
  balance Int    @default(0)

  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions PointTransaction[]
}

model PointTransaction {
  id        String          @id @default(cuid())
  userId    String
  accountId String
  amount    Int             // positive = earn, negative = spend
  type      PointTxType
  reason    String?
  createdAt DateTime        @default(now())

  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  account PointAccount @relation(fields: [accountId], references: [id])

  @@index([userId])
  @@index([accountId])
}

enum PointTxType {
  EARN_REVIEW
  EARN_EMOTION_TAG
  EARN_STATE_CHANGE
  SPEND_REDEEM
}

model Subscription {
  id                  String    @id @default(cuid())
  userId              String    @unique
  stripeSubId         String?   @unique // null when admin-granted
  plan                String    // "standard" or "pro"
  status              String    // active, canceled, past_due
  currentPeriodEnd    DateTime?
  currentPeriodStart  DateTime?
  cancelAtPeriodEnd   Boolean   @default(false)
  trialEnd            DateTime?
  grantedBy           String?   // admin userId who granted (null = Stripe)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Payment {
  id              String      @id @default(cuid())
  stripePaymentId String      @unique
  payerId         String
  recipientId     String?
  amount          Int         // in cents (JPY)
  currency        String      @default("jpy")
  type            PaymentType
  status          String      @default("succeeded")
  createdAt       DateTime    @default(now())

  @@index([payerId])
  @@index([recipientId])
}

enum PaymentType {
  TIP
  LETTER
  EPISODE_PURCHASE
  SUBSCRIPTION
}

// ============================================================
// Notifications
// ============================================================

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // comment, review, tip, score_ready, etc.
  title     String
  body      String?
  data      Json?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([createdAt])
}

// ============================================================
// Reading History Import
// ============================================================

model ReadingHistoryImport {
  id        String   @id @default(cuid())
  userId    String
  title     String
  author    String?
  source    String?  // "manual", "csv"
  importedAt DateTime @default(now())

  @@index([userId])
}

// ============================================================
// AI Settings & Templates
// ============================================================

model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  encrypted Boolean  @default(false)
  updatedAt DateTime @updatedAt
  updatedBy String?

  @@index([key])
}

model PromptTemplate {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?
  category    String   // "writing" | "editing" | "generation"
  prompt      String   @db.Text
  variables   Json?    // ["content", "genre"] etc.
  isBuiltIn   Boolean  @default(false)
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  usageLogs AiUsageLog[]

  @@index([category])
  @@index([isActive])
}

model AiUsageLog {
  id           String          @id @default(cuid())
  userId       String
  templateId   String?
  feature      String          // "writing_assist" | "scoring" | "synopsis_gen"
  inputTokens  Int             @default(0)
  outputTokens Int             @default(0)
  model        String
  durationMs   Int             @default(0)
  createdAt    DateTime        @default(now())

  template PromptTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([createdAt])
  @@index([feature])
}

model AiGenerationHistory {
  id            String   @id @default(cuid())
  userId        String
  workId        String
  episodeId     String?
  templateSlug  String
  promptSummary String?  @db.Text
  messages      Json     // [{ role: "user"|"assistant", content: string }]
  creditCost    Int      @default(1)
  model         String?
  premiumMode   Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  work Work @relation(fields: [workId], references: [id], onDelete: Cascade)

  @@index([userId, workId, createdAt])
}

model EpisodeDraft {
  id        String   @id @default(cuid())
  episodeId String   @default("")
  workId    String
  userId    String
  title     String
  content   String   @db.Text
  savedAt   DateTime @default(now())

  @@unique([userId, workId, episodeId])
  @@index([userId])
}

// ============================================================
// AI Insights & Embeddings
// ============================================================

model AiInsight {
  id        String   @id @default(cuid())
  workId    String
  userId    String?
  type      String
  content   Json
  createdAt DateTime @default(now())
  work      Work     @relation(fields: [workId], references: [id], onDelete: Cascade)
  @@unique([workId, userId, type])
  @@index([workId])
  @@index([userId])
}

model WorkEmbedding {
  id             String   @id @default(cuid())
  workId         String   @unique
  summary        String   @db.Text
  themes         Json
  tone           String?
  audience       String?
  characters     Json?    // キャラクター名配列
  worldType      String?  // "中世ファンタジー", "現代日本", "近未来SF"等
  emotionProfile Json?    // 意図された感情配列
  subGenre       String?  // より具体的なジャンル分類
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  work           Work     @relation(fields: [workId], references: [id], onDelete: Cascade)
}

model AiConversation {
  id           String   @id @default(cuid())
  userId       String
  workId       String
  characterId  String?
  mode         String   @default("companion") // "companion" | "character"
  messages     Json
  messageCount Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  @@unique([userId, workId, mode, characterId])
  @@index([userId])
  @@index([userId, workId])
}

// ============================================================
// Character Talk Revenue
// ============================================================

model CharacterTalkRevenue {
  id            String   @id @default(cuid())
  authorId      String
  readerId      String
  workId        String
  characterId   String?
  mode          String   @default("character")
  creditAmount  Int
  revenueYen    Int
  creditTxId    String?
  createdAt     DateTime @default(now())
  @@index([authorId, createdAt])
  @@index([workId])
}

// ============================================================
// Work Import
// ============================================================

model WorkImport {
  id               String   @id @default(cuid())
  userId           String
  workId           String?
  source           String   // "text_paste", "file_upload", "url_narou", "url_kakuyomu"
  sourceUrl        String?
  metadata         Json?
  status           String   @default("PENDING")
  totalChapters    Int      @default(0)
  importedChapters Int      @default(0)
  errorMessage     String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  @@index([userId])
  @@index([sourceUrl])
}

// ============================================================
// Episode Snapshots (Version History)
// ============================================================

model EpisodeSnapshot {
  id        String   @id @default(cuid())
  episodeId String
  userId    String
  title     String
  content   String   @db.Text
  wordCount Int      @default(0)
  label     String?
  createdAt DateTime @default(now())
  @@index([episodeId])
}

// ============================================================
// AI Creation Wizard
// ============================================================

model AiCreationLog {
  id            String   @id @default(cuid())
  workId        String
  userId        String
  stage         String   // "character_design" | "plot_architect" | "emotion_blueprint" | "chapter_outline" | "writing_assist"
  action        String   // "generated" | "accepted" | "rejected" | "edited"
  inputChars    Int      @default(0)
  outputChars   Int      @default(0)
  acceptedChars Int      @default(0)
  metadata      Json?
  createdAt     DateTime @default(now())

  work Work @relation(fields: [workId], references: [id], onDelete: Cascade)

  @@index([workId])
  @@index([userId])
}

model WorkCreationPlan {
  id                     String   @id @default(cuid())
  workId                 String   @unique
  characters             Json?
  plotOutline            Json?
  emotionBlueprint       Json?
  chapterOutline         Json?
  storySummary           Json?    // Auto-generated running summary of all episodes (cached)
  customFieldDefinitions Json?    // Custom field definitions for characters
  worldBuildingData      Json?    // World building data from wizard
  isWorldPublic          Boolean  @default(false)
  isEmotionPublic        Boolean  @default(false)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  work Work @relation(fields: [workId], references: [id], onDelete: Cascade)
}

// ============================================================
// Story Structure (Structured Character & Plot Data)
// ============================================================

model StoryCharacter {
  id           String   @id @default(cuid())
  workId       String
  name         String
  role         String               // 主人公/ヒロイン/敵役/脇役/メンター
  gender       String?
  age          String?              // "17歳" or "20代後半"
  personality  String?
  speechStyle  String?              // 口調（丁寧語、ぶっきらぼう等）
  firstPerson  String?              // 一人称（僕/私/俺/わたし等）
  appearance   String?   @db.Text
  background   String?   @db.Text
  motivation   String?
  arc          String?              // キャラクターアーク（成長・変化の方向）
  notes        String?   @db.Text   // 著者メモ
  isPublic     Boolean  @default(false)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  currentState  String?   @db.Text  // AI分析による現在の状態
  customFields  Json?              // Custom field values from wizard

  work          Work @relation(fields: [workId], references: [id], onDelete: Cascade)
  relationsFrom StoryCharacterRelation[] @relation("FromCharacter")
  relationsTo   StoryCharacterRelation[] @relation("ToCharacter")
  dialogueSamples CharacterDialogueSample[]

  @@index([workId])
}

model StoryCharacterRelation {
  id             String @id @default(cuid())
  fromCharacterId String
  toCharacterId   String
  relationType   String              // 恋人/親友/ライバル/師弟/家族/敵対
  description    String?

  from StoryCharacter @relation("FromCharacter", fields: [fromCharacterId], references: [id], onDelete: Cascade)
  to   StoryCharacter @relation("ToCharacter", fields: [toCharacterId], references: [id], onDelete: Cascade)

  @@unique([fromCharacterId, toCharacterId])
}

model StoryArc {
  id              String   @id @default(cuid())
  workId          String   @unique
  premise         String?  @db.Text
  centralConflict String?
  themes          String[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  work Work @relation(fields: [workId], references: [id], onDelete: Cascade)
  acts StoryAct[]
}

model StoryAct {
  id           String @id @default(cuid())
  arcId        String
  actNumber    Int                  // 1, 2, 3
  title        String
  summary      String? @db.Text
  turningPoint String?
  sortOrder    Int     @default(0)

  arc    StoryArc    @relation(fields: [arcId], references: [id], onDelete: Cascade)
  scenes StoryScene[]

  @@index([arcId])
}

model StoryScene {
  id            String   @id @default(cuid())
  actId         String
  episodeId     String?
  title         String
  summary       String?  @db.Text
  emotionTarget String?
  intensity     Int?                 // 1-10
  characters    String[]             // キャラクター名の配列
  status        String   @default("planned") // planned/writing/done
  sortOrder     Int      @default(0)

  act     StoryAct @relation(fields: [actId], references: [id], onDelete: Cascade)
  episode Episode? @relation(fields: [episodeId], references: [id])

  @@index([actId])
  @@index([episodeId])
}

// ============================================================
// AI Structural Analysis (Episode-level context for AI assist)
// ============================================================

model EpisodeAnalysis {
  id              String   @id @default(cuid())
  episodeId       String   @unique
  workId          String
  version         Int      @default(1)      // contentVersion at analysis time
  summary         String   @db.Text         // 200-300字の要約
  endState        String?  @db.Text         // エピソード終了時の状況
  narrativePOV    String?                   // 視点（一人称/三人称等）
  emotionalArc    String?                   // 感情の流れ（緊張→緩和等）
  timelineStart   String?                   // 時間軸の開始点
  timelineEnd     String?                   // 時間軸の終了点
  locations       Json?                     // [{ name, description }]
  characters      Json?                     // [{ name, role, action }]
  foreshadowings  Json?                     // [{ description, type }]
  dialogueSamples Json?                     // [{ character, line, context }]
  newWorldRules   Json?                     // [{ category, name, description }]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  episode Episode @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  work    Work    @relation(fields: [workId], references: [id], onDelete: Cascade)

  @@index([workId])
}

model Foreshadowing {
  id           String   @id @default(cuid())
  workId       String
  description  String   @db.Text          // 伏線の内容
  plantedIn    Int                         // 設置されたエピソード番号(orderIndex)
  resolvedIn   Int?                        // 回収されたエピソード番号
  status       String   @default("open")   // open/resolved/abandoned
  importance   String   @default("normal") // critical/normal/minor
  conditions   String?  @db.Text          // 回収条件
  relatedChars String[]                    // 関連キャラクター名

  work Work @relation(fields: [workId], references: [id], onDelete: Cascade)

  @@index([workId])
  @@index([status])
}

model WorldSetting {
  id           String   @id @default(cuid())
  workId       String
  category     String                     // geography/magic/social/technology/culture
  name         String                     // 設定名
  description  String   @db.Text          // 設定の詳細
  firstEpisode Int?                       // 初出エピソード番号
  lastEpisode  Int?                       // 最終登場エピソード番号
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  work Work @relation(fields: [workId], references: [id], onDelete: Cascade)

  @@unique([workId, category, name])
  @@index([workId])
}

model CharacterDialogueSample {
  id           String @id @default(cuid())
  workId       String
  characterId  String?                    // StoryCharacter.id (nullable for unlinked)
  characterName String                    // キャラクター名（直接保存）
  episodeOrder Int                        // エピソード番号
  line         String @db.Text            // セリフ
  context      String?                    // 発言状況
  emotion      String?                    // 感情（怒り/喜び/悲しみ等）

  work      Work            @relation(fields: [workId], references: [id], onDelete: Cascade)
  character StoryCharacter? @relation(fields: [characterId], references: [id], onDelete: SetNull)

  @@index([workId])
  @@index([characterId])
}

// ============================================================
// Invite Codes (Beta)
// ============================================================

// DEPRECATED - invitation system removed (kept for data preservation)
model InviteCode {
  id          String    @id @default(cuid())
  code        String    @unique
  label       String?   // admin note (e.g., "SNS配布用", "テスター向け")
  maxUses     Int       @default(1)
  usedCount   Int       @default(0)
  createdBy   String    // admin userId
  expiresAt   DateTime?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())

  usages InviteCodeUsage[]

  @@index([code])
  @@index([createdBy])
}

// DEPRECATED - invitation system removed (kept for data preservation)
model InviteCodeUsage {
  id           String   @id @default(cuid())
  inviteCodeId String
  userId       String
  usedAt       DateTime @default(now())

  inviteCode InviteCode @relation(fields: [inviteCodeId], references: [id], onDelete: Cascade)

  @@unique([inviteCodeId, userId])
  @@index([userId])
}

// ============================================================
// Referral Rewards
// DEPRECATED - referral reward system removed (kept for data preservation)
// ============================================================

model ReferralReward {
  id           String   @id @default(cuid())
  inviterId    String
  inviteeId    String
  triggerEvent String   // "first_work_published", "first_review"
  creditAmount Int
  claimed      Boolean  @default(false)
  claimedAt    DateTime?
  createdAt    DateTime @default(now())

  @@unique([inviterId, inviteeId, triggerEvent])
  @@index([inviterId])
  @@index([inviteeId])
}

// ============================================================
// SNS (Posts / Timeline)
// ============================================================

model Post {
  id          String    @id @default(cuid())
  authorId    String
  content     String    @db.Text
  postType    PostType  @default(ORIGINAL)

  // Embedded content
  workId      String?
  episodeId   String?
  highlightId String?

  // Repost / Quote
  repostOfId  String?
  quoteOfId   String?

  // Reply / Thread
  replyToId    String?
  threadRootId String?

  // Denormalized counters
  replyCount    Int     @default(0)
  repostCount   Int     @default(0)
  applauseCount Int     @default(0)
  bookmarkCount Int     @default(0)

  isDeleted   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  author    User       @relation("PostAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  work      Work?      @relation(fields: [workId], references: [id], onDelete: SetNull)
  episode   Episode?   @relation(fields: [episodeId], references: [id], onDelete: SetNull)
  highlight Highlight? @relation(fields: [highlightId], references: [id], onDelete: SetNull)
  repostOf  Post?      @relation("Repost", fields: [repostOfId], references: [id], onDelete: SetNull)
  quoteOf   Post?      @relation("Quote", fields: [quoteOfId], references: [id], onDelete: SetNull)
  replyTo   Post?      @relation("Reply", fields: [replyToId], references: [id], onDelete: SetNull)
  threadRoot Post?     @relation("Thread", fields: [threadRootId], references: [id], onDelete: SetNull)

  reposts    Post[]         @relation("Repost")
  quotes     Post[]         @relation("Quote")
  replies    Post[]         @relation("Reply")
  threadPosts Post[]        @relation("Thread")

  applause   Applause[]
  bookmarks  PostBookmark[]

  @@index([authorId, createdAt])
  @@index([replyToId])
  @@index([threadRootId])
  @@index([repostOfId])
  @@index([createdAt])
  @@index([workId])
}

enum PostType {
  ORIGINAL
  REPOST
  QUOTE
  REPLY
  AUTO_WORK
  AUTO_EPISODE
  AUTO_REVIEW
  AUTO_READING
}

model Applause {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([postId])
  @@index([userId])
}

model PostBookmark {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([userId, createdAt])
  @@index([postId])
}

// ============================================================
// Credits & Billing
// ============================================================

model CreditBalance {
  id               String    @id @default(cuid())
  userId           String    @unique
  balance          Int       @default(0)       // 合計残高（monthlyBalance + purchasedBalance）
  monthlyBalance   Int       @default(0)       // 月間付与分（期限あり）
  purchasedBalance Int       @default(0)       // 購入分（無期限）
  monthlyGranted   Int       @default(0)       // 今月の付与量
  lastGrantedAt    DateTime?
  updatedAt        DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CreditTransaction {
  id              String       @id @default(cuid())
  userId          String
  amount          Int          // +付与/購入, -消費/失効
  type            CreditTxType
  status          String       @default("confirmed") // pending | confirmed | refunded
  balance         Int          // トランザクション後の残高スナップショット
  relatedFeature  String?      // "writing_assist" | "creation_wizard" 等
  relatedModel    String?      // "claude-sonnet-4" | "claude-opus-4" 等
  aiUsageLogId    String?      // AiUsageLogへのリンク
  stripePaymentId String?
  description     String?
  createdAt       DateTime     @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

enum CreditTxType {
  MONTHLY_GRANT
  PURCHASE
  CONSUME
  EXPIRE
  ADMIN_GRANT
  ADMIN_REVOKE
  REFUND
  PLAN_CHANGE_ADJUST
  REVIEW_REWARD
  REFERRAL_REWARD
}

model CreditPurchase {
  id                    String   @id @default(cuid())
  userId                String
  amount                Int      // 購入クレジット数
  priceJpy              Int      // 支払額（円）
  stripePaymentIntentId String   @unique
  status                String   @default("completed")
  createdAt             DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ============================================================
// Editor Mode (AI全話自動生成)
// ============================================================

model EditorModeJob {
  id                String   @id @default(cuid())
  workId            String   @unique
  userId            String
  status            String   @default("designing")   // designing / taste_check / generating / paused / reviewing / completed
  aiMode            String   @default("normal")       // normal / premium
  generationMode    String   @default("batch")        // batch / confirm
  totalEpisodes     Int      @default(0)
  completedEpisodes Int      @default(0)
  creditsConsumed   Int      @default(0)
  designChatHistory Json?
  episodePlan       Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  work Work @relation(fields: [workId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

// ============================================================
// Engagement Loop
// ============================================================

model EpisodeReaction {
  id        String   @id @default(cuid())
  userId    String
  episodeId String
  workId    String
  claps     Int      @default(1)
  emotion   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  episode Episode @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  work    Work    @relation(fields: [workId], references: [id], onDelete: Cascade)

  @@unique([userId, episodeId])
  @@index([workId])
  @@index([episodeId])
  @@index([createdAt])
}

// ============================================================
// Announcements (お知らせ)
// ============================================================

model Announcement {
  id          String    @id @default(cuid())
  title       String
  content     String    @db.Text
  category    String    @default("update") // update / maintenance / feature / event
  isPublished Boolean   @default(false)
  isPinned    Boolean   @default(false)
  notifyAll   Boolean   @default(false)
  notifiedAt  DateTime?
  createdBy   String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  creator User @relation("announcementCreator", fields: [createdBy], references: [id])

  @@index([isPublished, createdAt])
}
